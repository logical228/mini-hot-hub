# 服务端口（默认 3001）
# PORT=3001

# 缓存 TTL（秒，默认 600）
# CACHE_TTL=600

# 上游请求超时（毫秒，默认 5000）
# FETCH_TIMEOUT=5000

# 允许跨域的前端地址（逗号分隔多个）
# 本地：http://localhost:5173
# 生产示例：https://mini-hot-pmge6uyoo-logical228-s-projects.vercel.app
# CLIENT_ORIGIN=https://mini-hot-pmge6uyoo-logical228-s-projects.vercel.app

# ── 开发专用：模拟平台抓取失败（NODE_ENV=production 时无效）──
# 用于验证前端单卡片 error 态；启用后会跳过该平台缓存
#
# MOCK_FAIL_WEIBO=1
# MOCK_FAIL_ZHIHU=1
# MOCK_FAIL_BILIBILI=1
# MOCK_FAIL_ALL=1
